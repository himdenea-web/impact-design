@charset "utf-8";

@import url("https://fonts.googleapis.com/css2?family=3DSyncopate:wght@700&=
family=3DInter:wght@400;900&display=3Dswap");

:root { --primary: #00f2ff; --secondary: #ff00ff; }

body { background: rgb(5, 5, 5); color: white; font-family: Inter, sans-ser=
if; display: flex; justify-content: center; align-items: center; min-height=
: 100vh; margin: 0px; overflow: hidden; }

.poster-container { position: relative; width: 350px; height: 600px; backgr=
ound: radial-gradient(circle, rgb(26, 26, 46), rgb(5, 5, 5)); border: 1px s=
olid rgba(255, 255, 255, 0.1); display: flex; justify-content: center; alig=
n-items: center; overflow: hidden; border-radius: 15px; }

.background-glow { position: absolute; width: 250px; height: 250px; backgro=
und: var(--primary); filter: blur(100px); opacity: 0.2; animation: 5s ease =
0s infinite alternate none running pulse; }

@keyframes pulse {=20
  0% { transform: scale(1); background: var(--primary); }
  100% { transform: scale(1.5); background: var(--secondary); }
}

.glass-card { position: relative; z-index: 10; width: 80%; padding: 30px; b=
ackground: rgba(255, 255, 255, 0.03); backdrop-filter: blur(15px); border-r=
adius: 20px; border: 1px solid rgba(255, 255, 255, 0.1); text-align: center=
; }

.glitch { font-family: Syncopate, sans-serif; font-size: 1.8rem; position: =
relative; color: white; text-transform: uppercase; }

.glitch::before { content: attr(data-text); position: absolute; left: 2px; =
text-shadow: -2px 0 var(--primary); clip: rect(10px, 999px, 30px, 0px); ani=
mation: 2s linear 0s infinite alternate-reverse none running glitch; }

@keyframes glitch {=20
  0% { clip: rect(15px, 999px, 20px, 0px); }
  100% { clip: rect(10px, 999px, 40px, 0px); }
}

.cta-button { margin-top: 20px; display: inline-block; padding: 10px 20px; =
border: 1px solid var(--primary); color: var(--primary); text-decoration: n=
one; font-size: 0.8rem; font-weight: bold; transition: 0.3s; }

.cta-button:hover { background: var(--primary); color: black; box-shadow: 0=
 0 20px var(--primary); }
